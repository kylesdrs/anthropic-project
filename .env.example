# Gmail Job Monitor - Environment Variables

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail API Credentials Path (OAuth client credentials JSON file)
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json

# Google Docs folder ID where output documents will be created
# (optional - if not set, docs will be created in root of Google Drive)
GOOGLE_DOCS_FOLDER_ID=

# Polling interval in minutes (how often to check for new emails)
POLL_INTERVAL_MINUTES=60

# Email search criteria
EMAIL_SUBJECT_FILTER=Upwork
EMAIL_SENDER_FILTER=

# Claude model to use for analysis
CLAUDE_MODEL=claude-sonnet-4-20250514
